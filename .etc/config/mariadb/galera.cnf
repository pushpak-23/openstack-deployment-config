[mysqld]
# --- I/O & Latency ---
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT

# --- Scaling for 2000+ VMs ---
# Increase buffer pool to handle the massive 'nova' and 'neutron' tables in RAM
innodb_buffer_pool_size = 256G
# Parallelize memory access across 80 cores
innodb_buffer_pool_instances = 80
# Disable hash index to prevent global mutex contention under high load
innodb_adaptive_hash_index = OFF

# --- Galera Concurrency ---
# Increase threads to apply writes from other nodes without blocking
wsrep_slave_threads = 128
# High connection limit for 200 tenants and multiple service workers
max_connections = 20000
thread_cache_size = 1024

# --- Performance Buffers ---
# Large log buffer for heavy bursts of VM creation/deletion
innodb_log_buffer_size = 512M
# Cache more tables to speed up complex joins in tenant queries
table_open_cache = 20000
